OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Optional: stronger model for project-module studio only (ideas, Starter Kits, handouts).
# If unset, uses OPENAI_MODEL. Set to your best available chat model (e.g. gpt-4o).
OPENAI_MODEL_PROJECT=

# Max completion tokens for project-module studio only (Starter Kit + multi-file bundles).
# Default 16384 (safe for many models). Raise if your model allows (e.g. 32768).
OPENAI_MAX_OUTPUT_TOKENS_PROJECT=16384

# Max chat messages (user + assistant pairs count as separate messages) sent to the model
# for /week-modular/stream. Older turns are dropped. Default: 24.
WEEK_STUDIO_MAX_HISTORY_MESSAGES=24
