# Copy to backend/.env and fill in secrets. Restart uvicorn after edits.
# If the key is in .env but requests still fail, confirm you run the API from
# `cd backend` (or rely on main.py loading this folder’s .env automatically).
#
# Backend LLM: Google Gemini only (no OpenAI).
# Google AI Studio / Gemini API: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIzaSyBsvWXE52GH3xvdbubyz_I4wcfxevGib9E

# Default: Gemini 2.5 Flash (see https://ai.google.dev/gemini-api/docs/models)
GEMINI_MODEL=gemini-2.5-flash

# Optional: stronger model for project-module lecture studio only (Starter Kits, handouts).
# If unset, uses GEMINI_MODEL.
GEMINI_MODEL_PROJECT=

# Optional: model for lecture-notes pipeline (Generate full notes). If unset, uses GEMINI_MODEL.
GEMINI_MODEL_LECTURE_NOTES=

# Optional: model for problem-set pipeline (auto-generate assignment). If unset, uses GEMINI_MODEL.
GEMINI_MODEL_PROBLEM_SET=

# Optional: model for PDF grading of problem sets. If unset, uses GEMINI_MODEL.
GEMINI_MODEL_PROBLEM_SET_GRADE=

# Max output tokens for lecture studio (non-project modules). Default 65536.
GEMINI_MAX_OUTPUT_TOKENS=65536

# Max output tokens for project-module lecture studio (multi-file bundles). Default 65536.
GEMINI_MAX_OUTPUT_TOKENS_PROJECT=

# Optional: lecture “read aloud” in Lecture workspace (ElevenLabs). Per chunk max 10k chars.
# Free tier: use a default/premade voice ID (e.g. Rachel below). Voice Library voices need a paid plan for API.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Default in code: eleven_flash_v2_5 (+ mp3_22050_32). Override if needed.
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_API_KEY=sk_5b75935e49fa26379ad11048049004110b162dfd03cc0d26

# Max chat messages (user + assistant pairs count as separate messages) sent to the model
# for /week-modular/stream. Older turns are dropped. Default: 24.
WEEK_STUDIO_MAX_HISTORY_MESSAGES=24
